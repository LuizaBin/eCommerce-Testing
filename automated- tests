import pytest
import random
import string
from playwright.sync_api import Page, expect


BASE_URL = "https://bookcart.azurewebsites.net"


def random_username(length=10):
    """Generate a random username to avoid duplicate registration errors."""
    return "testuser_" + "".join(random.choices(string.ascii_lowercase + string.digits, k=length))

